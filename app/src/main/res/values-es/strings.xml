    <string name="info_flight_time_title">Tiempo de vuelo</string>
    <string name="info_flight_time_text">Controla el tiempo predeterminado que la pelota permanece en el aire. (La fuerza del golpe y la inclinación del teléfono aumentarán o disminuirán este tiempo.)\n\n500-600ms: Difícil (Rápido)\n700-900ms: Medio\n1000-1200ms: Fácil (Lento)\n\n(Sincronizado con el oponente)</string>
    <string name="hit_window_label">Ventana de golpe: %1$d ms (%2$s)</string>
    <string name="info_hit_window_title">Ventana de golpe (Dificultad)</string>
    <string name="info_hit_window_text">Cambia el margen de error para el tiempo de tu golpe.\n\nVentana más grande = Más fácil de golpear.\nVentana más pequeña = Más difícil de golpear.\n\nRango: 200ms (Difícil) a 700ms (Fácil)\n\n(Sincronizado con el oponente)</string>
    <string name="how_to_play_safety">Cómo jugar y seguridad</string>
    <string name="safety_first">Seguridad primero</string>
    <string name="safety_strap">• Usa una correa para la muñeca.</string>
    <string name="safety_area">• Despeja tu área de juego.</string>
    <string name="gameplay">Jugabilidad</string>
    <string name="gameplay_hold">• Sostén el teléfono con la pantalla hacia AFUERA (lejos de la palma).</string>
    <string name="gameplay_yellow">• AMARILLO significa Entrante (Prepárate).</string>
    <string name="gameplay_green">• VERDE significa Golpear (Después del rebote).</string>
    <string name="gameplay_red">• ROJO significa Turno del oponente.</string>
    <string name="shot_types_risks">Tipos de tiro y riesgos</string>
    <string name="shot_types_desc">La fuerza del golpe y la inclinación del teléfono cambian tu tiro:</string>
    <string name="shot_flat">• Pantalla Vertical = GOLPE PLANO</string>
    <string name="shot_flat_desc">  Tiro estándar. Seguro y confiable.</string>
    <string name="shot_lob">• Pantalla Arriba = GLOBO</string>
    <string name="shot_lob_desc">  Arco lento y alto.</string>
    <string name="shot_lob_safe">  Seguro, te da tiempo para recuperarte.</string>
    <string name="shot_spike">• Pantalla Abajo = REMATE</string>
    <string name="shot_spike_desc">  ¡Rápido y agresivo!</string>
    <string name="shot_spike_risk">  Hace que la ventana de golpe del oponente sea más corta, pero</string>
    <string name="shot_spike_net">  Mayor probabilidad de golpear la red o salir fuera.</string>
    <string name="use_debug_tones">Usar tonos de depuración</string>
    <string name="info_debug_tones_title">Tonos de depuración</string>
    <string name="info_debug_tones_text">Si está habilitado, reproduce tonos simples en lugar de los efectos de sonido del juego.</string>
    <string name="debug_mode">Modo de depuración</string>
    <string name="info_debug_mode_title">Modo de depuración</string>
    <string name="info_debug_mode_text">Habilita una superposición en la pantalla del juego que muestra estadísticas técnicas como el tiempo de ida y vuelta (RTT), el estado exacto del juego y los valores brutos de los sensores.\n\n(Solo local)</string>
