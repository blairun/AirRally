    <string name="info_flight_time_title">Tempo de Voo</string>
    <string name="info_flight_time_text">Controla o tempo padrão que a bola fica no ar. (A força do balanço e a inclinação do celular aumentarão ou diminuirão esse tempo.)\n\n500-600ms: Difícil (Rápido)\n700-900ms: Médio\n1000-1200ms: Fácil (Lento)\n\n(Sincronizado com o oponente)</string>
    <string name="hit_window_label">Janela de Acerto: %1$d ms (%2$s)</string>
    <string name="info_hit_window_title">Janela de Acerto (Dificuldade)</string>
    <string name="info_hit_window_text">Altera a margem de erro para o tempo do seu balanço.\n\nJanela Maior = Mais fácil de acertar.\nJanela Menor = Mais difícil de acertar.\n\nFaixa: 200ms (Difícil) a 700ms (Fácil)\n\n(Sincronizado com o oponente)</string>
    <string name="how_to_play_safety">Como Jogar e Segurança</string>
    <string name="safety_first">Segurança Primeiro</string>
    <string name="safety_strap">• Use uma alça de pulso.</string>
    <string name="safety_area">• Limpe sua área de jogo.</string>
    <string name="gameplay">Jogabilidade</string>
    <string name="gameplay_hold">• Segure o celular com a tela para FORA (longe da palma).</string>
    <string name="gameplay_yellow">• AMARELO significa Chegando (Prepare-se).</string>
    <string name="gameplay_green">• VERDE significa Balançar (Após o Pulo).</string>
    <string name="gameplay_red">• VERMELHO significa Vez do Oponente.</string>
