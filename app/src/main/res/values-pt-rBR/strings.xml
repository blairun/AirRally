    <string name="shot_lob">• Tela Para Cima = LOB</string>
    <string name="shot_lob_desc">  Arco alto e lento.</string>
    <string name="shot_lob_safe">  Seguro, te dá tempo para recuperar.</string>
    <string name="shot_spike">• Tela Para Baixo = CORTADA</string>
    <string name="shot_spike_desc">  Rápido e Agressivo!</string>
    <string name="shot_spike_risk">  Diminui a janela de acerto do oponente, mas</string>
