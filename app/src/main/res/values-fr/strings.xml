    <string name="info_flight_time_title">Temps de vol</string>
    <string name="info_flight_time_text">Contrôle le temps par défaut que la balle reste en l\'air. (La force du swing et l\'inclinaison du téléphone augmenteront ou diminueront ce temps.)\n\n500-600ms : Difficile (Rapide)\n700-900ms : Moyen\n1000-1200ms : Facile (Lent)\n\n(Synchronisé avec l\'adversaire)</string>
    <string name="hit_window_label">Fenêtre de frappe : %1$d ms (%2$s)</string>
    <string name="info_hit_window_title">Fenêtre de frappe (Difficulté)</string>
    <string name="info_hit_window_text">Modifie la marge d\'erreur pour le timing de votre swing.\n\nFenêtre plus grande = Plus facile à frapper.\nFenêtre plus petite = Plus difficile à frapper.\n\nPlage : 200ms (Difficile) à 700ms (Facile)\n\n(Synchronisé avec l\'adversaire)</string>
    <string name="how_to_play_safety">Comment jouer et sécurité</string>
    <string name="safety_first">Sécurité d\'abord</string>
    <string name="safety_strap">• Utilisez une dragonne.</string>
    <string name="safety_area">• Dégagez votre aire de jeu.</string>
    <string name="gameplay">Jeu</string>
    <string name="gameplay_hold">• Tenez le téléphone avec l\'écran vers l\'EXTÉRIEUR (loin de la paume).</string>
    <string name="gameplay_yellow">• JAUNE signifie Arrivée (Préparez-vous).</string>
    <string name="gameplay_green">• VERT signifie Frapper (Après le rebond).</string>
    <string name="gameplay_red">• ROUGE signifie Tour de l\'adversaire.</string>
    <string name="shot_types_risks">Types de coups et risques</string>
    <string name="shot_types_desc">La force du swing et l\'inclinaison du téléphone changent votre coup :</string>
    <string name="shot_flat">• Écran Vertical = COUP PLAT</string>
    <string name="shot_flat_desc">  Coup standard. Sûr et fiable.</string>
    <string name="shot_lob">• Écran vers le haut = LOB</string>
    <string name="shot_lob_desc">  Arc lent et haut.</string>
    <string name="shot_lob_safe">  Sûr, vous donne le temps de récupérer.</string>
    <string name="shot_spike">• Écran vers le bas = SMASH</string>
    <string name="shot_spike_desc">  Rapide et agressif !</string>
    <string name="shot_spike_risk">  Rend la fenêtre de frappe de l\'adversaire plus courte, mais</string>
    <string name="shot_spike_net">  Plus grand risque de toucher le filet ou de sortir.</string>
