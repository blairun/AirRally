    <string name="info_flight_time_title">Flight Time</string>
    <string name="info_flight_time_text">Make the game feel faster or slower by changing the default time the ball stays in the air (from hit to bounce on opponent\'s side). Swing force and phone tilt will increase or decrease this time.\n\n500-600ms: Hard (Fast)\n700-900ms: Medium\n1000-1200ms: Easy (Slow)\n\n(Synced with opponent)</string>
    <string name="hit_window_label">Hit Window: %1$d ms (%2$s)</string>
    <string name="info_hit_window_title">Hit Window (Difficulty)</string>
    <string name="info_hit_window_text">Changes the margin of error for your swing timing; the valid swing window.\n\nLarger Window = Easier to hit.\nSmaller Window = Harder to hit.\n\nRange: 200ms (Hard) to 700ms (Easy)\n\n(Synced with opponent)</string>
    <string name="swing_sensitivity_label">Swing Sensitivity: %1$.1f</string>
    <string name="info_sensitivity_title">Swing Sensitivity</string>
    <string name="info_sensitivity_text">Minimum swing force required to trigger a soft swing. Medium and hard swings are scaled up from the minimum.\n\nLower = More Sensitive (Easier to trigger)\nHigher = Less Sensitive (Harder to trigger)\n\n(Local only)</string>
    <string name="how_to_play_safety">How to Play &amp; Safety</string>
    <string name="safety_first">Safety First</string>
    <string name="safety_strap">• Use a wrist strap.</string>
    <string name="safety_area">• Clear your play area.</string>
    <string name="gameplay">Gameplay</string>
    <string name="gameplay_hold">• Hold phone with screen facing OUT (away from palm).</string>
    <string name="gameplay_yellow">• YELLOW means Incoming (Get Ready).</string>
    <string name="gameplay_green">• GREEN means Swing (After Bounce).</string>
    <string name="gameplay_red">• RED means Opponent\'s Turn.</string>
    <string name="shot_types_risks">Shot Types &amp; Risks</string>
    <string name="shot_types_desc">Swing force and phone tilt change your shot:</string>
    <string name="shot_flat">• Screen Vertical = FLAT HIT</string>
    <string name="shot_flat_desc">  Standard shot. Safe and reliable.</string>
    <string name="shot_lob">• Screen Up = LOB</string>
    <string name="shot_lob_desc">  Slow, high arc.</string>
    <string name="shot_lob_safe">  Safe, gives you time to recover.</string>
    <string name="shot_smash">• Screen Down = SMASH</string>
    <string name="shot_smash_desc">  Fast &amp; Aggressive!</string>
    <string name="shot_smash_risk">  Makes opponent\'s hit window shorter, but</string>
    <string name="shot_smash_net">  Higher chance to hit net or off table.</string>
    <string name="use_debug_tones">Use Debug Tones</string>
    <string name="info_debug_tones_title">Debug Tones</string>
    <string name="info_debug_tones_text">If enabled, plays simple beep tones instead of the game sound effects.</string>
    <string name="debug_mode">Debug Mode</string>
    <string name="info_debug_mode_title">Debug Mode</string>
    <string name="info_debug_mode_text">Enables an overlay in the game screen showing technical stats like Round Trip Time (RTT), exact game state, and raw sensor values.\n\n(Local only)</string>
